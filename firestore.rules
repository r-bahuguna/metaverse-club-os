rules_version='2'

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper functions ──
    function isSignedIn() {
      return request.auth != null;
    }

    function belongsToOrg(orgId) {
      return isSignedIn() &&
        get(/databases/$(database)/documents/orgs/$(orgId)/members/$(request.auth.uid)).data != null;
    }

    function isOrgAdmin(orgId) {
      let member = get(/databases/$(database)/documents/orgs/$(orgId)/members/$(request.auth.uid)).data;
      return member != null && member.role in ['super_admin', 'owner', 'general_manager', 'manager'];
    }

    function isOrgOwner(orgId) {
      let member = get(/databases/$(database)/documents/orgs/$(orgId)/members/$(request.auth.uid)).data;
      return member != null && member.role in ['super_admin', 'owner'];
    }

    // ── Global user profile ──
    match /users/{uid} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && request.auth.uid == uid;
    }

    // ── Organization document ──
    match /orgs/{orgId} {
      allow read: if belongsToOrg(orgId);
      allow create: if isSignedIn(); // Anyone can create an org
      allow update: if isOrgOwner(orgId);
      allow delete: if false; // No client delete

      // ── Org members ──
      match /members/{uid} {
        allow read: if belongsToOrg(orgId);
        allow create, update: if isOrgAdmin(orgId);
        allow delete: if isOrgOwner(orgId);
      }

      // ── Real-time tips (written by API routes, read by dashboard) ──
      match /tips_realtime/{tipId} {
        allow read: if belongsToOrg(orgId);
        allow write: if false; // Server-only writes via Admin SDK
      }

      // ── Live visitors (written by API routes) ──
      match /visitors_live/{visitorId} {
        allow read: if belongsToOrg(orgId);
        allow write: if false;
      }

      // ── Visitor log (historical) ──
      match /visitor_log/{logId} {
        allow read: if belongsToOrg(orgId);
        allow write: if false;
      }

      // ── Active state (DJ, Host) ──
      match /active_state/{stateId} {
        allow read: if belongsToOrg(orgId);
        allow write: if false;
      }

      // ── Stats ──
      match /stats/{docId} {
        allow read: if belongsToOrg(orgId);
        allow write: if false;
      }

      // ── DJ sessions ──
      match /dj_sessions/{sessionId} {
        allow read: if belongsToOrg(orgId);
        allow write: if false;
      }

      // ── Staff feed ──
      match /staff_feed/{feedId} {
        allow read: if belongsToOrg(orgId);
        allow create: if belongsToOrg(orgId);
        allow update, delete: if isOrgAdmin(orgId);
      }

      // ── Audit logs ──
      match /audit_logs/{logId} {
        allow read: if isOrgAdmin(orgId);
        allow create: if belongsToOrg(orgId);
        allow update, delete: if false;
      }

      // ── Events ──
      match /events/{eventId} {
        allow read: if belongsToOrg(orgId);
        allow create, update: if isOrgAdmin(orgId);
        allow delete: if isOrgOwner(orgId);
      }

      // ── Notifications ──
      match /notifications/{notifId} {
        allow read: if belongsToOrg(orgId);
        allow create: if isOrgAdmin(orgId);
        allow update: if belongsToOrg(orgId) && request.auth.uid == resource.data.userId;
        allow delete: if isOrgAdmin(orgId);
      }
    }
  }
}
